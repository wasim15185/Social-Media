{
  "compilerOptions": {
    /* Project Structure */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Language & Environment */
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "types": ["node"],

    /* Module Resolution */
    "moduleResolution": "node",
    "esModuleInterop": true,

    /* Type Checking */
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    /* Development */
    "sourceMap": true,

    /* JSON Support */
    "resolveJsonModule": true,

    /* Recommended for Node */
    "allowSyntheticDefaultImports": true
  },

  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
